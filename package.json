{
  "name": "rename-me",
  "version": "1.0.0-alpha.0",
  "description": "{{todo}}",
  "keywords": [
    "{{todo}}"
  ],
  "repository": "git@github.com:{{todo}}.git",
  "author": "{{todo}} <{{todo}}@mediamonks.com>",
  "license": "MIT",
  "exports": {
    "import": "./dist/index.js"
  },
  "type": "module",
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "jest ./src/",
    "build": "npm-run-all -s clean build:*",
    "build:ts": "tsc -p ./tsconfig.build.json",
    "clean": "npm-run-all clean:*",
    "clean:test": "shx rm -rf coverage .nyc_output",
    "clean:npm": "shx rm -rf dist",
    "lint": "eslint --ext .js,.ts .",
    "fix": "npm run lint -- --fix",
    "format": "prettier \"**/*.{js,ts,md,json}\" --write --loglevel warn",
    "typecheck": "tsc --project tsconfig.json --noEmit --noUnusedLocals",
    "prepare-publish": "ts-node-esm ../scripts/preparePublish.ts",
    "prepublishOnly": "npm run prepare-publish",
    "prepare": "husky install"
  },
  "lint-staged": {
    "*.{js,ts,md,json}": "prettier --write"
  },
  "prettier": "@mediamonks/prettier-config",
  "eslintConfig": {
    "overrides": [
      {
        "files": [
          "*.js"
        ],
        "extends": [
          "@mediamonks/eslint-config"
        ]
      },
      {
        "files": [
          "*.ts"
        ],
        "parserOptions": {
          "project": "./tsconfig.json"
        },
        "extends": [
          "@mediamonks/eslint-config",
          "@mediamonks/eslint-config-typescript"
        ]
      },
      {
        "files": [
          "*.test.ts",
          "scripts/**/*"
        ],
        "rules": {
          "import/no-extraneous-dependencies": "off"
        }
      }
    ],
    "ignorePatterns": [
      "dist/",
      "node_modules/"
    ]
  },
  "devDependencies": {
    "@jest/globals": "^29.3.1",
    "@mediamonks/eslint-config": "^2.0.7",
    "@mediamonks/eslint-config-typescript": "^1.0.9",
    "@mediamonks/prettier-config": "^1.0.1",
    "@swc/core": "^1.3.27",
    "@swc/jest": "^0.2.24",
    "@types/jest": "^29.2.3",
    "@types/shelljs": "^0.8.11",
    "eslint": "^8.28.0",
    "husky": "^8.0.3",
    "jest": "^29.3.1",
    "jest-environment-jsdom": "^29.3.1",
    "lint-staged": "^13.1.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^2.8.0",
    "shelljs": "^0.8.5",
    "shx": "^0.3.4",
    "ts-jest": "^29.0.3",
    "ts-node": "^10.9.1",
    "typescript": "^4.9.3"
  }
}
